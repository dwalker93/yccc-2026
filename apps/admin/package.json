{
  "name": "admin",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "auth:schema:gen": "bun x auth@latest generate --config ./src/lib/auth/auth.ts --output ./src/lib/db/schemas/auth-schema.ts",
    "auth:db:gen": "drizzle-kit generate --config ./drizzle.auth.config.ts",
    "auth:db:push": "drizzle-kit push --config ./drizzle.auth.config.ts",
    "auth:db:studio": "drizzle-kit studio --config ./drizzle.auth.config.ts",
    "app:db:gen": "drizzle-kit generate --config ./drizzle.app.config.ts",
    "app:db:push": "drizzle-kit push --config ./drizzle.app.config.ts",
    "app:db:studio": "drizzle-kit studio --config ./drizzle.app.config.ts",
    "app:db:seed": "bun src/migrations/seed.ts"
  },
  "dependencies": {
    "@better-auth/infra": "^0.2.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@getbrevo/brevo": "^5.0.4",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/query-core": "^5.100.9",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/redis": "^1.38.0",
    "@vercel/functions": "^3.5.0",
    "@workspace/shared": "workspace:*",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "3.8.0",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/webpack": "^4.3.0",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-form-devtools": "^0.2.22",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
